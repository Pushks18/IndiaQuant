# Shoonya (Finvasia) API — get from shoonya.com after opening a demat account
# Vendor code and API key come from the API activation page in the Shoonya app
SHOONYA_API_KEY=your_api_key_here
SHOONYA_USER_ID=your_user_id_here
SHOONYA_PASSWORD=your_password_here
SHOONYA_TOTP_SECRET=your_totp_secret_here   # from Google Authenticator setup
SHOONYA_VENDOR_CODE=your_vendor_code_here
SHOONYA_IMEI=mac                             # any fixed string for desktop login

# Anthropic Claude API — get from console.anthropic.com (optional until agents are needed)
ANTHROPIC_API_KEY=sk-ant-...

# Finnhub — free key from finnhub.io
FINNHUB_KEY=your_finnhub_key_here

# NewsAPI — free key from newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# PostgreSQL + TimescaleDB
# Docker: docker run -d --name timescale -p 5432:5432 -e POSTGRES_PASSWORD=yourpassword timescale/timescaledb:latest-pg15
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/india_quant

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=

# OpenRouter — free LLM API for sentiment + bull/bear narratives.
# Get a free key at openrouter.ai/keys (no card required for free tier)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_MODEL_FALLBACK=openai/gpt-oss-120b:free
